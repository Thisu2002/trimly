generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  customer
  stylist
}

enum StylistStatus {
  on_duty
  on_leave
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
}

model User {
  id        String   @id @default(uuid())
  auth0Sub  String   @unique
  name      String?
  email     String   @unique
  phone     String?
  address   String?
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminSalon      Salon?   @relation("SalonAdmin")
  stylistProfile  Stylist?
  customerProfile Customer?
}

model Customer {
  id        String   @id @default(uuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments Appointment[]
  hairProfile     UserHairProfile?
  facePhotos      UserFacePhotos?
  pendingPayments PendingPayment[]
  loyaltyPoints  CustomerPoints?
  redemptions    RewardRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserHairProfile {
  id        String   @id @default(uuid())

  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  faceShape  String?  // oval | round | square | heart | diamond | oblong
  hairType   String?  // straight | wavy | curly | coily
  hairLength String?  // short | medium | long
  styleGoal  String?  // low_maintenance | trendy | professional | volume | repair
  previousServices String[] @default([])
  detectionMethod  String?  // "mirror" | "manual"
  
  faceLandmarks Json? // stores number[] directly

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserFacePhotos {
  id        String   @id @default(uuid())

  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  frontPhoto String  // base64 data URL or URL
  leftPhoto  String
  rightPhoto String

  generatedPhotos Json @default("{}") 
  // shape: { [styleId]: { front?: string, left?: string, right?: string } }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Salon {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  address   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminUserId String @unique
  admin       User   @relation("SalonAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)

  loyaltyProgram LoyaltyProgram?

  stylists      Stylist[]
  services      Service[]
  categories    Category[]
  businessHours SalonBusinessHour[]
  appointments  Appointment[]
}

model Stylist {
  id        String   @id @default(uuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  bio               String?
  yearsOfExperience Int?
  status            StylistStatus @default(on_duty)

  services            StylistService[]
  weeklyShifts        StaffWeeklyShift[]
  appointmentServices AppointmentService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([salonId])
}

model SalonBusinessHour {
  id        String    @id @default(uuid())

  salonId   String
  salon     Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek
  openTime  String
  closeTime String

  slotDuration Int     @default(15)
  isClosed     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([salonId, dayOfWeek])
  @@index([salonId, dayOfWeek])
}

model StaffWeeklyShift {
  id        String    @id @default(uuid())

  stylistId String
  stylist   Stylist   @relation(fields: [stylistId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  isOff     Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([stylistId, dayOfWeek])
  @@index([stylistId, dayOfWeek])
}

model Style {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String   // Haircut, Color, Treatment, Styling

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  durationMin Int
  priceLkr    Int

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  styleId String?
  style   Style? @relation(fields: [styleId], references: [id])

  stylists            StylistService[]
  appointmentServices AppointmentService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId])
  @@index([categoryId])
  @@index([styleId])
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([name, salonId])
  @@index([salonId])
}

model StylistService {
  stylistId String
  serviceId String

  stylist Stylist @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([stylistId, serviceId])
  @@index([serviceId])
}

model Appointment {
  id         String            @id @default(uuid())

  customerId String
  customer   Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  salonId String
  salon   Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  date      DateTime
  startTime String
  endTime   String
  totalLkr  Int

  status AppointmentStatus @default(pending)

  payment        Payment?
  pendingPayment PendingPayment?

  services AppointmentService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, date])
  @@index([customerId, date])
}

model AppointmentService {
  id String @id @default(uuid())

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  stylistId String
  stylist   Stylist @relation(fields: [stylistId], references: [id], onDelete: Restrict)

  sequence  Int
  startTime String
  endTime   String

  priceLkr    Int
  durationMin Int

  @@index([appointmentId])
  @@index([serviceId])
  @@index([stylistId])
  @@index([stylistId, startTime, endTime])
  @@unique([appointmentId, sequence])
}

model Payment {
  id String @id @default(uuid())

  appointmentId String @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  amountLkr Int
  status    String   // pending | paid | failed
  method    String?  // payhere
  payherePaymentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PendingPayment {
  id String @id @default(cuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  salonId String
  date    DateTime
  startTime String

  totalLkr Float
  bookingSnapshot Json

  failed Boolean @default(false)

  appointmentId String? @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  createdAt DateTime @default(now())
}

model LoyaltyProgram {
  id      String @id @default(uuid())
  salonId String @unique
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  // Points rules — stored as separate rows for flexibility
  rules   LoyaltyRule[]
  tiers   LoyaltyTier[]
  rewards LoyaltyReward[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Each rule is one earning action, e.g. "service_completed" = 10 pts
model LoyaltyRule {
  id          String         @id @default(uuid())
  programId   String
  program     LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  action      String  // "service_completed" | "review_submitted" | "monthly_visit" | "spending_per_100"
  label       String  // display name
  description String
  points      Int
  iconKey     String  // "check" | "message" | "calendar" | "dollar"  (for frontend icon map)
  colorKey    String  // "green" | "blue" | "purple" | "gray"         (for frontend color map)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programId, action])
}

// Tiers are ordered by sortOrder ascending (0 = base/Bronze)
model LoyaltyTier {
  id          String         @id @default(uuid())
  programId   String
  program     LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  name        String
  threshold   Int     // min points to reach this tier
  multiplier  Float   // point earning multiplier
  benefits    String[]
  sortOrder   Int     // 0-based, determines color assignment on frontend

  customerPoints CustomerPoints[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programId, name])
  @@unique([programId, sortOrder])
  @@index([programId])
}

model LoyaltyReward {
  id          String         @id @default(uuid())
  programId   String
  program     LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  name         String
  description  String
  pointsCost   Int
  tierRequired String  // tier name — matched at redemption time
  active       Boolean @default(true)

  redemptions RewardRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programId])
}

// Per-customer points balance + current tier
model CustomerPoints {
  id          String   @id @default(uuid())
  customerId  String   @unique
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  tierId      String?
  tier        LoyaltyTier? @relation(fields: [tierId], references: [id])

  totalPoints    Int @default(0)
  lifetimePoints Int @default(0)  // never decremented, used for tier calculation

  updatedAt DateTime @updatedAt
}

// Log of every redemption
model RewardRedemption {
  id         String        @id @default(uuid())
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  rewardId   String
  reward     LoyaltyReward @relation(fields: [rewardId], references: [id], onDelete: Restrict)

  pointsSpent Int
  redeemedAt  DateTime @default(now())

  @@index([customerId])
  @@index([rewardId])
}