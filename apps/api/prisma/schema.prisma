generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  customer
}

model User {
  id       String @id @default(uuid())
  auth0Sub String @unique
  email    String @unique
  role     Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}