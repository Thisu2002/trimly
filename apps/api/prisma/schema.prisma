generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  customer
  stylist
}

enum StylistStatus {
  on_duty
  on_leave
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
}

model User {
  id        String   @id @default(uuid())
  auth0Sub  String   @unique
  name      String?
  email     String   @unique
  phone     String?
  address   String?
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminSalon     Salon?   @relation("SalonAdmin")
  stylistProfile Stylist?
  customerProfile Customer?
}

model Customer {
  id        String   @id @default(uuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Salon {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminUserId String @unique
  admin       User   @relation("SalonAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)

  stylists      Stylist[]
  services      Service[]
  categories    Category[]
  businessHours SalonBusinessHour[]
  appointments  Appointment[]
}

model Stylist {
  id        String   @id @default(uuid())

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  bio               String?
  yearsOfExperience Int?
  status            StylistStatus @default(on_duty)

  services     StylistService[]
  weeklyShifts StaffWeeklyShift[]
  appointmentServices AppointmentService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([salonId])
}

model SalonBusinessHour {
  id        String    @id @default(uuid())
  salonId   String
  salon     Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek
  openTime  String
  closeTime String
  slotDuration  Int   @default(15)
  isClosed  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([salonId, dayOfWeek])
  @@index([salonId, dayOfWeek])
}

model StaffWeeklyShift {
  id        String    @id @default(uuid())
  stylistId String
  stylist   Stylist   @relation(fields: [stylistId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  isOff     Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([stylistId, dayOfWeek])
  @@index([stylistId, dayOfWeek])
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  durationMin Int
  priceLkr    Int

  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  stylists            StylistService[]
  appointmentServices AppointmentService[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([salonId])
  @@index([categoryId])
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  services    Service[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([name, salonId])
  @@index([salonId])
}

model StylistService {
  stylistId String
  serviceId String

  stylist   Stylist @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([stylistId, serviceId])
  @@index([serviceId])
}

model Appointment {
  id         String            @id @default(uuid())
  customerId String
  customer   Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  salonId    String
  salon      Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)

  date       DateTime
  startTime  String
  endTime    String
  totalLkr   Int
  status     AppointmentStatus @default(pending)

  services   AppointmentService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, date])
  @@index([customerId, date])
}

model AppointmentService {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  stylistId     String
  stylist       Stylist     @relation(fields: [stylistId], references: [id], onDelete: Restrict)

  sequence      Int
  startTime     String
  endTime       String

  priceLkr      Int
  durationMin   Int

  @@index([appointmentId])
  @@index([serviceId])
  @@index([stylistId])
  @@index([stylistId, startTime, endTime])
  @@unique([appointmentId, sequence])
}